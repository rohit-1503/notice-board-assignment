generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}

model Notice {
  id          Int       @id @default(autoincrement())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime @default(now())
  image       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority, publishDate])
}